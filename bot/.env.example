# Telegram Bot Token (от BotFather)
BOT_TOKEN=123456789:ABCDefGHIjklmnoPQRstuvWXYZ

# Telegram App credentials (для подключения аккаунтов через телефон/QR в боте)
TG_API_ID=123456
TG_API_HASH=0123456789abcdef0123456789abcdef

# Ограничение доступа к рассылке (user_id владельца, можно через запятую)
OWNER_ID=123456789

# Таймзона расписания рассылки
BROADCAST_TZ=Europe/Madrid

# Storage чат/канал для сохранения постов (Bot API) и чтения для рассылки (Telethon).
# Можно указать @username или numeric chat_id вида -100...
BROADCAST_STORAGE_CHANNEL=-1003970814563

# Для «Тест» в рассылке: сколько секунд ждать перед проверкой, что сообщение ещё существует
BROADCAST_TEST_VERIFY_SECONDS=60

# MTProto login (подключение аккаунта в меню рассылки)
MT_CODE_TTL_SECONDS=120
# MT_SESSIONS_DIR=/data/mt_sessions
# MT_ACCOUNTS_PATH=/data/mtproto_accounts.json
